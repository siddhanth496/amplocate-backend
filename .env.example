# ── Database ──────────────────────────────────────────────────────────────────
# SQLite for quick local runs / tests:
DATABASE_URL=sqlite+aiosqlite:///./voltara.db
# Postgres for docker-compose / production (postgres:// URLs are auto-normalised):
# DATABASE_URL=postgresql://user:password@localhost:5432/evplatform

# ── Cache ─────────────────────────────────────────────────────────────────────
# Leave empty to disable caching (app still works). Set for docker/prod:
# REDIS_URL=redis://localhost:6379/0
REDIS_URL=
CACHE_TTL_SECONDS=90

# ── Auth ──────────────────────────────────────────────────────────────────────
JWT_SECRET=change-me-in-production
DEV_MODE=true

# ── Data ingestion ────────────────────────────────────────────────────────────
# On first boot with an empty DB, auto-import default regions from OpenStreetMap
# (no API key needed). Set false to disable.
IMPORT_ON_EMPTY=true
# Full Delhi-NCR import (OCM + OSM + Google) on every startup — needs the keys below.
IMPORT_NCR_ON_START=false

# Optional API keys — importers that need them are skipped when unset.
# Free key from openchargemap.org (My Profile → My Applications):
OCM_API_KEY=
# Paid; Places API (New) enabled:
GOOGLE_MAPS_API_KEY=
